    <select id="findUserWithPasswordByName" parameterType="String" resultMap="UserWithPasswordResult">
        select u.*, p.id as pid, p.password, p.role
        from users u join tb_password p on u.uid = p.uid
        where u.uname = #{uname}
    </select>

    <resultMap id="UserWithPasswordResult" type="Users">
        <id property="uid" column="uid" />
        <association property="passwordObj" javaType="Password">
            <id property="id" column="pid" />
            <result property="password" column="password" />
            <result property="role" column="role" />
        </association>
    </resultMap>

    <select id="findUserWithOrder" resultMap="UserWithOrder" parameterType="int">
        select * from users u join tb_order o on u.uid=o.userid where uid=#{uid}
    </select>
    <resultMap id="UserWithOrder" type="Users">
        <id property="uid" column="uid"/>
        <collection property="orderList" ofType="Order">
            <id property="id" column="id" />
            <result property="productname" column="productname" />
            <result property="price" column="price" />
            <result property="number" column="number" />
        </collection>
    </resultMap>

</mapper>