<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="yandifei.study.dao.StudentMapper">
    <select id="findStudentBySname" parameterType="String" resultType="yandifei.study.domain.Student">
        select * from t_student where sname = #{sname}
    </select>
</mapper>