# ------------------------------------------------------------------
# Essential defaults for Docker Compose deployments.
# Docker Compose 部署的核心默认配置。
# 仅包含服务启动所需的最小变量集合。
#
# Only include variables required for services to start.
#
# For a default deployment, copy this file to .env and run:
#   默认部署：将本文件复制为 .env，然后运行：
#   docker compose up -d
#
# Optional and provider-specific variables live under docker/envs/.
# 可选变量和供应商特定变量存放在 docker/envs/ 目录下。
# Copy an optional *.env.example file beside itself without the
# .example suffix when you need those advanced settings.
# 需要高级设置时，将对应的 *.env.example 文件复制为去掉 .example 后缀的同名文件即可。
# Values in docker/.env take precedence over docker/envs/*.env files.
# docker/.env 中的值优先级高于 docker/envs/*.env 文件中的值。
# ------------------------------------------------------------------

# =============================================================================
# 核心服务 URL —— 配置各服务组件之间的通信地址
# =============================================================================

# 控制台前端访问API的URL（浏览器端使用）
# 留空则使用相对路径，通常不需要修改
CONSOLE_API_URL=
# 服务端内部访问控制台API的URL，固定为 api 容器名:5001 端口
SERVER_CONSOLE_API_URL=http://api:5001
# 控制台Web前端的访问URL
# 留空则使用默认的相对路径
CONSOLE_WEB_URL=
# 对外暴露的服务API地址
# 留空则不对外开放服务API
SERVICE_API_URL=
# 触发器URL，用于外部服务回调触发工作流
# 部署到服务器时需改为实际域名或IP
TRIGGER_URL=http://localhost
# 应用前端访问API的URL
# 留空则使用相对路径
APP_API_URL=
# 应用Web前端的访问URL
# 留空则使用默认的相对路径
APP_WEB_URL=
# 文件访问的基础URL（对外暴露）
# 留空则使用相对路径
FILES_URL=
# 内部文件访问URL（服务间通信使用）
# 留空则自动使用内部地址
INTERNAL_FILES_URL=
# Webhook端点URL模板，{hook_id} 会被替换为实际的hook标识
# 部署到服务器时需将 localhost 改为实际域名
ENDPOINT_URL_TEMPLATE=http://localhost/e/{hook_id}
# WebSocket连接URL（浏览器端使用）
# 部署到服务器时需将 localhost 改为实际域名，ws:// 改为 wss://（如启用HTTPS）
NEXT_PUBLIC_SOCKET_URL=ws://localhost

# =============================================================================
# 运行时与安全 —— 控制服务运行时的语言环境、加密密钥、部署模式等
# =============================================================================

# 系统语言环境，C.UTF-8 保证英文环境下正确处理UTF-8字符
LANG=C.UTF-8
# 系统区域设置，同上
LC_ALL=C.UTF-8
# Python标准输出编码，确保日志中的中文等字符正常显示
PYTHONIOENCODING=utf-8
# Python包管理器uv的缓存目录，使用tmpfs减少磁盘写入
UV_CACHE_DIR=/tmp/.uv-cache
# 应用加密密钥——最重要安全配置之一
# 留空则自动在 storage 目录下生成持久化密钥
# 生产环境建议设置一个随机字符串（可用 openssl rand -hex 32 生成）
# 更改此值会导致已有加密数据无法解密！
SECRET_KEY=
# 初始化管理员密码
# 首次部署时设置，用于创建管理员账号的初始密码
# 仅在首次初始化时生效，之后修改无效
INIT_PASSWORD=
# 部署环境标识
# PRODUCTION=生产模式 | DEVELOPMENT=开发模式 | TESTING=测试模式
DEPLOY_ENV=PRODUCTION
# 检查更新的API地址，Dify启动时会检查是否有新版本
# 设置为空可禁用更新检查
CHECK_UPDATE_URL=https://updates.dify.ai
# OpenAI API兼容的基础URL
# 如果使用OpenAI官方服务则不需要改
# 如果使用中转代理或兼容接口（如OneAPI），改为对应地址
OPENAI_API_BASE=https://api.openai.com/v1
# 数据库迁移开关
# true=启动时自动执行数据库迁移（表结构变更）
# false=跳过迁移（生产环境升级时可能需要手动控制）
MIGRATION_ENABLED=true
# 文件访问超时时间（秒），控制生成的文件下载链接的有效期
# 超时后链接失效，需重新生成
FILES_ACCESS_TIMEOUT=300
# 协作模式开关，启用后支持多人同时编辑工作流
# 需配合 api_websocket 服务使用
# Remove `collaboration` from COMPOSE_PROFILES to stop the dedicated websocket service.
# 从 COMPOSE_PROFILES 中移除 `collaboration` 可停止专用的 WebSocket 服务
ENABLE_COLLABORATION_MODE=true

# =============================================================================
# 日志与服务端工作进程 —— 控制日志输出格式、级别和服务端并发能力
# =============================================================================

# 日志级别：DEBUG | INFO | WARNING | ERROR | CRITICAL
# 生产环境建议 INFO 或 WARNING，调试时可用 DEBUG
LOG_LEVEL=INFO
# 日志输出格式：text=纯文本 | json=JSON格式（方便日志采集系统解析）
LOG_OUTPUT_FORMAT=text
# 日志文件路径（容器内路径）
LOG_FILE=/app/logs/server.log
# 单个日志文件最大大小（MB）
# 超过此大小会自动轮转
LOG_FILE_MAX_SIZE=20
# 日志文件保留数量，超过此数量会删除最旧的日志
LOG_FILE_BACKUP_COUNT=5
# 日志时间戳格式，遵循 Python strftime 格式
LOG_DATEFORMAT=%Y-%m-%d %H:%M:%S
# 日志时区
LOG_TZ=UTC
# Flask框架调试模式
# 生产环境务必设为 false，否则可能泄露敏感信息
DEBUG=false
# Flask调试模式的额外开关
FLASK_DEBUG=false
# 请求日志开关
# True=记录每个HTTP请求的详细信息（用于审计和调试）
ENABLE_REQUEST_LOGGING=False
# 服务绑定的IP地址
# 0.0.0.0=监听所有网络接口 | 127.0.0.1=仅本地访问
DIFY_BIND_ADDRESS=0.0.0.0
# 服务监听端口
DIFY_PORT=5001
# API服务Worker进程数
# 建议值：CPU核心数 × 2 + 1，但不超过实际需要
# 1=单进程（开发/低负载环境）
SERVER_WORKER_AMOUNT=1
# Gunicorn Worker类型
# gevent=协程模式（适合IO密集型） | sync=同步模式（适合CPU密集型）
SERVER_WORKER_CLASS=gevent
# 每个Worker的最大并发连接数
SERVER_WORKER_CONNECTIONS=10
# WebSocket Worker类
# geventwebsocket 支持WebSocket协议
API_WEBSOCKET_WORKER_CLASS=geventwebsocket.gunicorn.workers.GeventWebSocketWorker
# WebSocket Worker最大连接数（需大于预期并发用户数）
API_WEBSOCKET_WORKER_CONNECTIONS=1000
# WebSocket Gunicorn超时时间（秒）
# WebSocket长连接需要较大超时值
API_WEBSOCKET_GUNICORN_TIMEOUT=360
# Gunicorn请求超时时间（秒）
# 对于需要长时间处理的请求（如生成大段文本），需适当增大
GUNICORN_TIMEOUT=360
# Celery异步任务Worker类
# 留空使用默认（prefork），可选 gevent（适合IO密集型任务）
CELERY_WORKER_CLASS=
# Celery Worker数量
# 建议根据CPU核心数和任务量调整
CELERY_WORKER_AMOUNT=4
# Celery自动扩缩容
# true=根据队列负载自动调整Worker数量
CELERY_AUTO_SCALE=false
# 自动扩缩时的最大Worker数
CELERY_MAX_WORKERS=
# 自动扩缩时的最小Worker数
CELERY_MIN_WORKERS=
# Worker健康检查是否禁用
# true=禁用（减少资源消耗） | false=启用
COMPOSE_WORKER_HEALTHCHECK_DISABLED=true
# Worker健康检查间隔
COMPOSE_WORKER_HEALTHCHECK_INTERVAL=30s
# Worker健康检查超时时间
COMPOSE_WORKER_HEALTHCHECK_TIMEOUT=30s

# =============================================================================
# 数据库 —— PostgreSQL 连接和连接池配置
# =============================================================================

# 数据库类型：postgresql | mysql
# 切换数据库需同时修改 COMPOSE_PROFILES 中的 ${DB_TYPE:-postgresql}
DB_TYPE=postgresql
# 数据库用户名
DB_USERNAME=postgres
# 数据库密码
# 生产环境务必修改为强密码！
DB_PASSWORD=difyai123456
# 数据库主机名（Docker Compose中对应服务名）
DB_HOST=db_postgres
# 数据库端口
DB_PORT=5432
# 数据库名称
DB_DATABASE=dify
# SQLAlchemy连接池大小
# 建议值：并发请求数的1/3到1/2
SQLALCHEMY_POOL_SIZE=30
# 连接池溢出大小（当连接池满时允许的额外连接数）
# 实际最大连接数 = POOL_SIZE + MAX_OVERFLOW
SQLALCHEMY_MAX_OVERFLOW=10
# 连接回收时间（秒）
# 超过此时间的空闲连接会被回收，防止数据库端断开导致连接无效
SQLALCHEMY_POOL_RECYCLE=3600
# SQLAlchemy SQL语句回显
# true=打印所有SQL语句（调试用，生产环境设为false）
SQLALCHEMY_ECHO=false
# 连接预检
# true=从连接池取出连接时先发一个ping验证连接有效（增加开销但更可靠）
SQLALCHEMY_POOL_PRE_PING=false
# 连接池LIFO策略
# true=后进先出（适合连接数紧张的场景，更可能复用热连接）
# false=先进先出
SQLALCHEMY_POOL_USE_LIFO=false
# 获取连接的超时时间（秒）
SQLALCHEMY_POOL_TIMEOUT=30
# 连接归还时的重置策略
# rollback=回滚未提交的事务 | commit=提交 | none=不做处理
SQLALCHEMY_POOL_RESET_ON_RETURN=rollback
# PostgreSQL数据目录（容器内）
PGDATA=/var/lib/postgresql/data/pgdata
# PostgreSQL最大连接数
# 需大于应用连接池的最大连接数（POOL_SIZE + MAX_OVERFLOW × Worker数）
POSTGRES_MAX_CONNECTIONS=200
# PostgreSQL共享缓冲区大小
# 建议设为系统内存的25%
POSTGRES_SHARED_BUFFERS=128MB
# 单个查询操作的工作内存
POSTGRES_WORK_MEM=4MB
# 维护操作（VACUUM、CREATE INDEX等）的工作内存
POSTGRES_MAINTENANCE_WORK_MEM=64MB
# PostgreSQL有效缓存大小（告知优化器可用的系统缓存）
# 建议设为系统内存的50-75%
POSTGRES_EFFECTIVE_CACHE_SIZE=4096MB
# 语句超时时间（毫秒），0=不限制
# 设置限制可防止慢查询占用资源
POSTGRES_STATEMENT_TIMEOUT=0
# 事务空闲超时（毫秒），0=不限制
# 超过此时间自动终止空闲事务，防止长事务阻塞
POSTGRES_IDLE_IN_TRANSACTION_SESSION_TIMEOUT=0

# =============================================================================
# Redis 与 Celery —— 缓存、消息队列和异步任务配置
# =============================================================================

# Redis主机名（Docker Compose中对应服务名）
REDIS_HOST=redis
# Redis端口
REDIS_PORT=6379
# Redis用户名（Redis 6+支持ACL）
# 留空使用默认用户
REDIS_USERNAME=
# Redis密码
# 生产环境务必修改为强密码！
REDIS_PASSWORD=difyai123456
# Redis SSL连接
REDIS_USE_SSL=false
# SSL证书验证级别
# CERT_NONE=不验证 | CERT_REQUIRED=必须验证 | CERT_OPTIONAL=可选验证
REDIS_SSL_CERT_REQS=CERT_NONE
# SSL CA证书路径（启用SSL且需要验证时设置）
REDIS_SSL_CA_CERTS=
# SSL客户端证书路径
REDIS_SSL_CERTFILE=
# SSL客户端私钥路径
REDIS_SSL_KEYFILE=
# Redis数据库编号（0-15）
# Dify默认使用0号库
REDIS_DB=0
# Redis键前缀
# 设置前缀可避免多个Dify实例共用同一Redis时的键冲突
REDIS_KEY_PREFIX=
# Redis最大连接数配置
# 留空使用Redis默认值
REDIS_MAX_CONNECTIONS=
# Redis操作失败重试次数
REDIS_RETRY_RETRIES=3
# 重试退避基础值（秒）
# 第一次重试等待 base×2^0 秒，第n次等待 base×2^n 秒
REDIS_RETRY_BACKOFF_BASE=1.0
# 重试退避上限（秒）
# 单次等待不超过此值
REDIS_RETRY_BACKOFF_CAP=10.0
# Redis Socket读取超时（秒）
REDIS_SOCKET_TIMEOUT=5.0
# Redis Socket连接超时（秒）
REDIS_SOCKET_CONNECT_TIMEOUT=5.0
# Redis健康检查间隔（秒）
REDIS_HEALTH_CHECK_INTERVAL=30
# Celery消息代理URL（完整连接字符串）
# redis://:密码@主机:端口/数据库编号
# 格式：redis://:password@host:port/db_num
CELERY_BROKER_URL=redis://:difyai123456@redis:6379/1
# Celery后端存储类型
# redis=使用Redis存储任务结果
CELERY_BACKEND=redis
# 消息代理是否使用SSL
BROKER_USE_SSL=false
# Celery任务注解（JSON格式，可对特定任务设置自定义参数）
# null=不设置任何注解
CELERY_TASK_ANNOTATIONS=null
# 事件总线Redis URL
# 用于服务间的事件通知（如工作流更新通知）
# 留空则使用 CELERY_BROKER_URL 的配置
EVENT_BUS_REDIS_URL=
# 事件总线Redis通道类型
# pubsub=发布/订阅模式 | stream=流模式（支持消息持久化）
EVENT_BUS_REDIS_CHANNEL_TYPE=pubsub
# 是否使用Redis集群模式
EVENT_BUS_REDIS_USE_CLUSTERS=false
# 事件总线监听器加入超时（毫秒）
EVENT_BUS_LISTENER_JOIN_TIMEOUT_MS=2000

# =============================================================================
# Web与应用限制 —— 跨域、Cookie、Sentry监控、内容安全策略
# =============================================================================

# 服务API跨域允许的来源
# *=允许所有来源（开发环境） | 生产环境建议设为具体域名
WEB_API_CORS_ALLOW_ORIGINS=*
# 控制台跨域允许的来源
CONSOLE_CORS_ALLOW_ORIGINS=*
# Cookie作用域
# 留空使用当前域名
# 如需在子域名间共享Cookie，设为 .example.com
COOKIE_DOMAIN=
# Next.js前端Cookie作用域
NEXT_PUBLIC_COOKIE_DOMAIN=
# Next.js批量请求并发数
# 控制前端同时发送的API请求数量
NEXT_PUBLIC_BATCH_CONCURRENCY=5
# API服务Sentry DSN（错误监控）
# 留空不启用Sentry
# 格式：https://<key>@sentry.io/<project_id>
API_SENTRY_DSN=
# API Sentry 追踪采样率（0.0-1.0）
# 1.0=100%采样（生产环境可能产生大量数据）
API_SENTRY_TRACES_SAMPLE_RATE=1.0
# API Sentry 性能分析采样率（0.0-1.0）
API_SENTRY_PROFILES_SAMPLE_RATE=1.0
# Web前端Sentry DSN
WEB_SENTRY_DSN=
# Amplitude分析API Key（用户行为分析）
# 留空不启用
AMPLITUDE_API_KEY=
# 文本生成超时时间（毫秒）
# 超过此时间未收到LLM响应则中断请求
TEXT_GENERATION_TIMEOUT_MS=60000
# 内容安全策略白名单
# 允许加载资源的额外域名，多个用空格分隔
CSP_WHITELIST=
# 是否允许iframe嵌入Dify页面
# true=允许 | false=禁止（推荐，防止点击劫持）
ALLOW_EMBED=false
# 是否允许内联样式
# true=允许 | false=禁止（推荐，更安全的CSP策略）
ALLOW_INLINE_STYLES=false
# 是否允许 data: 协议的URL
# 存在安全风险，建议保持false
ALLOW_UNSAFE_DATA_SCHEME=false
# RAG检索的最大Top K值
# 限制知识库检索返回的最大片段数，防止单次请求检索过多内容
TOP_K_MAX_VALUE=10
# 索引最大分段Token长度
# 单段文本超过此长度会被进一步切分
# 值越大单段信息越完整，但可能超过模型的上下文窗口
INDEXING_MAX_SEGMENTATION_TOKENS_LENGTH=4000
# 循环节点的最大循环次数
# 防止死循环导致资源耗尽
LOOP_NODE_MAX_COUNT=100
# 工作流中工具节点的最大工具数
MAX_TOOLS_NUM=10
# 并行执行的最大任务数
MAX_PARALLEL_LIMIT=10
# Agent迭代的最大次数
# 限制Agent自主推理的步数，防止无限循环
MAX_ITERATIONS_NUM=99
# 工作流树的最大深度
# 防止嵌套过深的工作流结构
MAX_TREE_DEPTH=50
# 是否启用 Jina Reader 网页抓取
# Jina Reader用于将网页内容转换为LLM可读的Markdown格式
ENABLE_WEBSITE_JINAREADER=true
# 是否启用 Firecrawl 网页抓取（替代抓取引擎）
ENABLE_WEBSITE_FIRECRAWL=true
# 是否启用 Watercrawl 网页抓取（替代抓取引擎）
ENABLE_WEBSITE_WATERCRAWL=true
# 是否启用单美元符号LaTeX渲染
# 启用后 $...$ 会被解析为LaTeX公式（可能与普通文本中的$冲突）
NEXT_PUBLIC_ENABLE_SINGLE_DOLLAR_LATEX=false
# Enable preview features still in development (currently the /create and
# /refine slash commands in the "Go to Anything" command palette).
# 启用仍在开发中的预览功能（目前包括"Go to Anything"命令面板中的 /create 和 /refine 快捷命令）
NEXT_PUBLIC_ENABLE_FEATURE_PREVIEW=false
# 是否启用 ViNext 实验性功能
# ViNext是Dify的实验性视觉交互功能
EXPERIMENTAL_ENABLE_VINEXT=false

# =============================================================================
# 存储与默认向量数据库 —— 文件存储方式和向量检索后端
# =============================================================================

# 存储类型
# opendal=使用Apache OpenDAL统一存储抽象（支持多种后端）
# 可选：local | s3 | azure-blob | google-cloud-storage | aliyun-oss | tencent-cos
STORAGE_TYPE=opendal
# OpenDAL存储方案
# fs=本地文件系统 | s3=Amazon S3兼容 | azblob=Azure Blob
OPENDAL_SCHEME=fs
# OpenDAL本地文件系统根目录（相对于容器内/app/api路径）
OPENDAL_FS_ROOT=storage
# 向量数据库类型
# weaviate | qdrant | milvus | pgvector | chroma | opensearch | elasticsearch | oracle | oceanbase 等
VECTOR_STORE=weaviate
# 向量索引名称前缀
# 用于在同一个向量数据库中区分不同Dify实例的数据
VECTOR_INDEX_NAME_PREFIX=Vector_index
# Weaviate HTTP端点
WEAVIATE_ENDPOINT=http://weaviate:8080
# Weaviate API密钥
WEAVIATE_API_KEY=WVF5YThaHlkYwhGUSmCRgsX3tD5ngdN8pkih
# Weaviate gRPC端点（用于高性能向量检索）
WEAVIATE_GRPC_ENDPOINT=grpc://weaviate:50051
# Weaviate分词方式
# word=按词分词 | field=按字段分词 | whitespace=按空白分词 | lowercase=小写分词
WEAVIATE_TOKENIZATION=word
# Weaviate数据持久化路径
WEAVIATE_PERSISTENCE_DATA_PATH=/var/lib/weaviate
# Weaviate默认查询返回数量上限
WEAVIATE_QUERY_DEFAULTS_LIMIT=25
# 是否允许匿名访问Weaviate
WEAVIATE_AUTHENTICATION_ANONYMOUS_ACCESS_ENABLED=true
# Weaviate默认向量化模块
# none=不使用自动向量化（由Dify自行向量化）
WEAVIATE_DEFAULT_VECTORIZER_MODULE=none
# Weaviate集群主机名
WEAVIATE_CLUSTER_HOSTNAME=node1
# 是否启用Weaviate API Key认证
WEAVIATE_AUTHENTICATION_APIKEY_ENABLED=true
# 允许的API Key列表
WEAVIATE_AUTHENTICATION_APIKEY_ALLOWED_KEYS=WVF5YThaHlkYwhGUSmCRgsX3tD5ngdN8pkih
# API Key关联的用户邮箱
WEAVIATE_AUTHENTICATION_APIKEY_USERS=hello@dify.ai
# 是否启用管理员列表授权
WEAVIATE_AUTHORIZATION_ADMINLIST_ENABLED=true
# 管理员用户列表
WEAVIATE_AUTHORIZATION_ADMINLIST_USERS=hello@dify.ai
# 是否禁用Weaviate遥测（向Weaviate官方发送使用数据）
WEAVIATE_DISABLE_TELEMETRY=false
# 启用GSE中文分词器（用于中文文本搜索优化）
WEAVIATE_ENABLE_TOKENIZER_GSE=false
# 启用Kagome日文分词器
WEAVIATE_ENABLE_TOKENIZER_KAGOME_JA=false
# 启用Kagome韩文分词器
WEAVIATE_ENABLE_TOKENIZER_KAGOME_KR=false

# =============================================================================
# 沙箱与SSRF代理 —— 代码执行安全隔离和防服务端请求伪造
# =============================================================================

# 代码执行沙箱端点
# 所有工作流中的代码节点在此沙箱中执行，与主服务隔离
CODE_EXECUTION_ENDPOINT=http://sandbox:8194
# 代码执行沙箱API密钥
CODE_EXECUTION_API_KEY=dify-sandbox
# 是否验证沙箱的SSL证书
CODE_EXECUTION_SSL_VERIFY=True
# 沙箱连接池最大连接数
CODE_EXECUTION_POOL_MAX_CONNECTIONS=100
# 沙箱连接池最大保持活跃连接数
CODE_EXECUTION_POOL_MAX_KEEPALIVE_CONNECTIONS=20
# 保持活跃连接过期时间（秒）
CODE_EXECUTION_POOL_KEEPALIVE_EXPIRY=5.0
# 沙箱连接超时（秒）
CODE_EXECUTION_CONNECT_TIMEOUT=10
# 沙箱读取超时（秒）
# 代码执行可能需要较长时间
CODE_EXECUTION_READ_TIMEOUT=60
# 沙箱写入超时（秒）
CODE_EXECUTION_WRITE_TIMEOUT=10
# 沙箱API密钥（与CODE_EXECUTION_API_KEY保持一致）
SANDBOX_API_KEY=dify-sandbox
# Gin框架运行模式
# release=生产模式 | debug=调试模式 | test=测试模式
SANDBOX_GIN_MODE=release
# 沙箱Worker超时时间（秒）
# 单个代码执行任务的最大时长
SANDBOX_WORKER_TIMEOUT=15
# 是否允许沙箱访问网络
# true=允许（代码中可以发起网络请求）
# false=禁止（更安全，但限制部分功能）
SANDBOX_ENABLE_NETWORK=true
# 沙箱HTTP代理（所有HTTP请求通过SSRF代理转发）
SANDBOX_HTTP_PROXY=http://ssrf_proxy:3128
# 沙箱HTTPS代理
SANDBOX_HTTPS_PROXY=http://ssrf_proxy:3128
# 沙箱服务端口
SANDBOX_PORT=8194
# PyPI镜像URL
# 在国内部署时可设为清华/阿里等PyPI镜像以加速依赖安装
PIP_MIRROR_URL=
# SSRF代理HTTP转发地址
# 所有外部HTTP请求经过此代理，防止服务端请求伪造攻击
SSRF_PROXY_HTTP_URL=http://ssrf_proxy:3128
# SSRF代理HTTPS转发地址
SSRF_PROXY_HTTPS_URL=http://ssrf_proxy:3128
# SSRF代理HTTP监听端口
SSRF_HTTP_PORT=3128
# Squid核心转储目录
SSRF_COREDUMP_DIR=/var/spool/squid
# SSRF反向代理端口（用于转发沙箱请求）
SSRF_REVERSE_PROXY_PORT=8194
# 沙箱主机名
SSRF_SANDBOX_HOST=sandbox
# SSRF默认请求超时（秒）
SSRF_DEFAULT_TIME_OUT=5
# SSRF默认连接超时（秒）
SSRF_DEFAULT_CONNECT_TIME_OUT=5
# SSRF默认读取超时（秒）
SSRF_DEFAULT_READ_TIME_OUT=5
# SSRF默认写入超时（秒）
SSRF_DEFAULT_WRITE_TIME_OUT=5
# SSRF代理连接池最大连接数
SSRF_POOL_MAX_CONNECTIONS=100
# SSRF代理连接池最大保持活跃连接数
SSRF_POOL_MAX_KEEPALIVE_CONNECTIONS=20
# SSRF代理保持活跃连接过期时间（秒）
SSRF_POOL_KEEPALIVE_EXPIRY=5.0

# =============================================================================
# 插件守护进程 —— 管理第三方插件的安装、运行和远程调试
# =============================================================================

# 插件专用数据库名
# 插件实例数据独立存储在单独的数据库中
DB_PLUGIN_DATABASE=dify_plugin
# 对外暴露的插件守护进程端口
EXPOSE_PLUGIN_DAEMON_PORT=5002
# 插件守护进程内部端口
PLUGIN_DAEMON_PORT=5002
# 插件守护进程密钥（用于插件守护进程与主服务之间的认证）
# 生产环境务必修改！
PLUGIN_DAEMON_KEY=lYkiYYT6owG+71oLerGzA7GXCgOT++6ovaezWAjpCjf+Sjc3ZtU+qUEi
# 插件守护进程URL（主服务调用插件守护进程的地址）
PLUGIN_DAEMON_URL=http://plugin_daemon:5002
# 插件包最大大小（字节）
# 限制上传的插件包体积，50MB = 52428800
PLUGIN_MAX_PACKAGE_SIZE=52428800
# 插件模型Schema缓存TTL（秒）
# 缓存模型参数定义，减少重复解析
PLUGIN_MODEL_SCHEMA_CACHE_TTL=3600
# 插件性能分析开关（pprof为Go性能分析工具）
PLUGIN_PPROF_ENABLED=false
# 插件调试主机地址
# 0.0.0.0=允许远程调试 | 127.0.0.1=仅本地调试
PLUGIN_DEBUGGING_HOST=0.0.0.0
# 插件调试端口
PLUGIN_DEBUGGING_PORT=5003
# 对外暴露的插件调试主机
EXPOSE_PLUGIN_DEBUGGING_HOST=localhost
# 对外暴露的插件调试端口
EXPOSE_PLUGIN_DEBUGGING_PORT=5003
# Dify内部API密钥（插件调用主服务API的认证密钥）
# 生产环境务必修改！
PLUGIN_DIFY_INNER_API_KEY=QaHbTe77CtuXmsfyhR7+vRjI/+XbV1AaFy691iy+kGDv2Jvy0/eAh8Y1
# Dify内部API URL（插件调用主服务的地址）
PLUGIN_DIFY_INNER_API_URL=http://api:5001
# 是否强制验证插件签名
# true=只允许安装有签名的插件（推荐，更安全）
# false=允许安装未签名的插件（开发调试用）
FORCE_VERIFYING_SIGNATURE=true
# 插件STDIO缓冲区大小（字节）
PLUGIN_STDIO_BUFFER_SIZE=1024
# 插件STDIO最大缓冲区大小（字节）
PLUGIN_STDIO_MAX_BUFFER_SIZE=5242880
# Python环境初始化超时（秒）
# 插件首次加载时需要创建虚拟环境，可能需要较长时间
PLUGIN_PYTHON_ENV_INIT_TIMEOUT=120
# 插件最大执行超时（秒）
# 单次插件调用的最大允许时长
PLUGIN_MAX_EXECUTION_TIMEOUT=600
# 插件存储类型
# local=本地文件系统 | s3=AWS S3 | azure-blob=Azure Blob | aliyun-oss=阿里云OSS | tencent-cos=腾讯云COS
PLUGIN_STORAGE_TYPE=local
# 插件本地存储根目录
PLUGIN_STORAGE_LOCAL_ROOT=/app/storage
# 插件工作目录（插件运行时的当前工作目录）
PLUGIN_WORKING_PATH=/app/storage/cwd
# 已安装插件存放路径（相对路径）
PLUGIN_INSTALLED_PATH=plugin
# 插件包缓存路径
PLUGIN_PACKAGE_CACHE_PATH=plugin_packages
# 插件媒体资源缓存路径
PLUGIN_MEDIA_CACHE_PATH=assets
# 插件OSS存储桶名称（使用对象存储时配置）
PLUGIN_STORAGE_OSS_BUCKET=
# 是否启用插件Sentry错误监控
PLUGIN_SENTRY_ENABLED=false
# 插件Sentry DSN
PLUGIN_SENTRY_DSN=
# 是否启用插件市场
# true=允许从Dify官方市场安装插件
MARKETPLACE_ENABLED=true
# 插件市场API地址
MARKETPLACE_API_URL=https://marketplace.dify.ai
# 插件市场前端访问地址
MARKETPLACE_URL=

# =============================================================================
# Nginx 与 Docker Compose —— 反向代理、HTTPS和编排配置
# =============================================================================

# Nginx服务器名（域名）
# _=匹配所有请求 | 具体域名=只匹配该域名
NGINX_SERVER_NAME=_
# 是否启用HTTPS
# true=启用SSL/TLS | false=仅HTTP
NGINX_HTTPS_ENABLED=false
# Nginx HTTP端口
NGINX_PORT=80
# Nginx SSL端口
NGINX_SSL_PORT=443
# SSL证书文件名（需放在 ./nginx/ssl 目录下）
NGINX_SSL_CERT_FILENAME=dify.crt
# SSL私钥文件名（需放在 ./nginx/ssl 目录下）
NGINX_SSL_CERT_KEY_FILENAME=dify.key
# SSL协议版本
# TLSv1.2 TLSv1.3=最安全配置 | 如需兼容旧客户端可加 TLSv1.1
NGINX_SSL_PROTOCOLS=TLSv1.2 TLSv1.3
# Nginx工作进程数
# auto=自动匹配CPU核心数 | 具体数字=手动指定
NGINX_WORKER_PROCESSES=auto
# 客户端请求体最大大小
# 影响文件上传、图片生成等场景
NGINX_CLIENT_MAX_BODY_SIZE=100M
# Nginx Keepalive超时（秒）
# 长连接保持时间，影响客户端连接复用效率
NGINX_KEEPALIVE_TIMEOUT=65
# Nginx代理读取超时
# 对于SSE流式响应等长连接场景需较大值
NGINX_PROXY_READ_TIMEOUT=3600s
# Nginx代理发送超时
NGINX_PROXY_SEND_TIMEOUT=3600s
# 是否启用Certbot自动HTTPS证书
# 启用后可与certbot服务配合自动申请Let's Encrypt证书
NGINX_ENABLE_CERTBOT_CHALLENGE=false
# Socket.IO上游服务地址（协作模式的WebSocket）
NGINX_SOCKET_IO_UPSTREAM=api_websocket:5001
# 对外暴露的Nginx HTTP端口
EXPOSE_NGINX_PORT=80
# 对外暴露的Nginx SSL端口
EXPOSE_NGINX_SSL_PORT=443
# Docker Compose启用的服务配置文件
# 格式：向量数据库名,数据库类型,协作模式
# ${VECTOR_STORE:-weaviate}=使用VECTOR_STORE变量值，默认为weaviate
# ${DB_TYPE:-postgresql}=使用DB_TYPE变量值，默认为postgresql
# collaboration=启用协作模式的WebSocket服务
# 如需禁用协作模式，移除 collaboration
COMPOSE_PROFILES=${VECTOR_STORE:-weaviate},${DB_TYPE:-postgresql},collaboration
