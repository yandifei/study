/**index.wxss**/
page {
  background-color: #f4f4f4;
  /* padding-bottom: 20rpx; */
  /* height: 100%;
  height: 100vh; */
  display: flex;
  flex-direction: column;
}
.scrollarea {
  flex: 1;
}
.container {
  padding: 20rpx;
}

/* 卡片容器 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

/* 点击反馈效果 */
.card-hover {
  transform: scale(0.98);
  background-color: #fafafa;
}

/* 卡片头部 */
.card-head {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-weight: bold;
  font-size: 34rpx;
  background-color: #fef7e0; /* 浅黄色背景 */
  color: #B85C1A;           /* 深橙色文字 */
}

/* 卡片内容区 */
.card-content {
  padding: 30rpx;
}

/* 图片样式 */
.card-img {
  width: 100%;
  height: 360rpx; /* 建议使用 rpx 以适配不同屏幕 */
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  display: block;
}

/* 文字样式 */
.card-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  text-align: justify;
}