<!--
  pages/search/search.wxml
  和我这个开发者进行聊天，实现一人人脑识别，没有人工智能的内容
  auto-height="{{true}}" 让输入框随内容长高，max-height: 208rpx 在 4 行处封顶，超出的内容触发 overflow-y: auto 内部滚动。缺了任何一个都不行——之前 WXML 有 auto-height 但 CSS 丢了 max-height，所以无限长高、永不滚动。
-->
<view class="chat-page">

  <!-- 侧边栏遮罩 -->
  <view wx:if="{{showSidebar}}" class="sidebar-overlay" style="top: {{totalNavHeight}}px;" bindtap="handleToggleSidebar"></view>

  <!-- 历史会话侧边栏 -->
  <view class="sidebar {{showSidebar ? 'sidebar-open' : ''}}" style="top: {{totalNavHeight}}px;">
    <view class="sidebar-header">
      <text class="sidebar-title">对话记录</text>
      <view class="sidebar-new-btn" bindtap="handleNewChat">
        <text class="sidebar-new-icon">+</text>
        <text class="sidebar-new-text">新对话</text>
      </view>
    </view>
    <scroll-view class="sidebar-list" scroll-y enhanced show-scrollbar="{{false}}">
      <view wx:for="{{conversations}}" wx:key="id"
        class="sidebar-item {{conversationId === item.id ? 'sidebar-item-active' : ''}}"
        bindtap="handleSelectConversation" data-id="{{item.id}}" data-name="{{item.name}}">
        <view class="sidebar-item-content">
          <image class="sidebar-item-avatar" src="/res/default-avatar.png" mode="aspectFill" />
          <view class="sidebar-item-info">
            <text class="sidebar-item-name">{{item.name || '新对话'}}</text>
            <text class="sidebar-item-time">{{item.updated_at}}</text>
          </view>
        </view>
        <view class="sidebar-item-delete" catchtap="handleDeleteConversation" data-id="{{item.id}}">
          <text class="sidebar-delete-text">✕</text>
        </view>
      </view>
      <view wx:if="{{conversations.length === 0}}" class="sidebar-empty"><text>暂无历史对话</text></view>
    </scroll-view>
  </view>

  <!-- 主聊天区域 -->
  <view class="chat-main">

    <!-- 顶部导航栏（白色极简） -->
    <view class="nav-bar" style="height: {{totalNavHeight}}px; padding-top: {{statusBarHeight}}px;">
      <view class="nav-bar-content" style="height: {{navBarHeight}}px;">
        <view class="nav-left" bindtap="handleToggleSidebar">
          <image class="nav-icon" src="/res/search/nav_icon.png" mode="aspectFill"/>
        </view>
        <text class="nav-title">鉴赏者(开发者)</text>
        <view class="nav-right">
          <text class="nav-icon" bindtap="handleNewChat">✧</text>
        </view>
      </view>
    </view>
    
    <!-- 消息滚动区 -->
    <scroll-view class="message-scroll" scroll-y="{{true}}"
      scroll-into-view="{{scrollToView}}" bindscrolltolower="onScrollToLower"
      lower-threshold="50" show-scrollbar="{{false}}" enhanced="{{true}}" bounces="{{false}}">
      <view class="message-list">

        <!-- 欢迎区域 -->
        <view wx:if="{{messages.length === 0}}" class="welcome-area">
          <view class="welcome-logo"><text class="welcome-emoji">🎨</text></view>
          <text class="welcome-text">{{welcomeMsg}}</text>
          <view class="suggestion-list">
            <view wx:for="{{suggestions}}" wx:key="*this" class="suggestion-item"
              bindtap="handleSendSuggestion" data-text="{{item}}">
              <text class="suggestion-dot">✦</text><text>{{item}}</text>
            </view>
          </view>
          <view class="welcome-upload" bindtap="handleChooseImage">
            <text class="welcome-upload-icon">📷</text>
            <text class="welcome-upload-text">上传图片开始解析</text>
          </view>
        </view>

        <!-- 消息列表 -->
        <block wx:for="{{messages}}" wx:key="id">

          <!-- 用户消息（无头像） -->
          <view wx:if="{{item.role === 'user'}}" class="message-row user-row">
            <view class="message-bubble user-bubble">
              <view wx:if="{{item.files && item.files.length > 0}}" class="msg-images">
                <image wx:for="{{item.files}}" wx:key="id" wx:for-item="f"
                  class="msg-image-item" src="{{f.path || f.url}}" mode="aspectFill"
                  bindtap="handlePreviewFile" data-path="{{f.path || f.url}}" />
              </view>
              <text wx:if="{{item.content}}" class="bubble-text" user-select="{{true}}">{{item.content}}</text>
            </view>
          </view>

          <view wx:if="{{item.role === 'assistant'}}" class="message-row ai-row">
            <view class="message-body">
              <!-- 思考中 -->
              <view wx:if="{{item.status === 'sending'}}" class="thinking-indicator">
                <view class="thinking-dots"><view class="dot"></view><view class="dot"></view><view class="dot"></view></view>
                <text>思考中...</text>
              </view>

              <!-- 消息内容 -->
              <view wx:elif="{{item.content || item.status === 'streaming'}}" class="ai-content">
                <!-- 思考过程折叠块 -->
                <view wx:if="{{item.thought}}" class="think-toggle" bindtap="handleToggleThought" data-id="{{item.id}}">
                  <text>{{item.showThought ? '▾' : '▸'}} 💭 思考过程</text>
                </view>
                <view wx:if="{{item.thought && item.showThought}}" class="think-content">
                  <text user-select="{{true}}">{{item.thought}}</text>
                </view>
                <text class="ai-text" user-select="{{true}}">{{item.content}}</text>
                <text wx:if="{{item.status === 'streaming'}}" class="streaming-cursor">▊</text>
              </view>

              <!-- 失败 -->
              <view wx:if="{{item.status === 'failed'}}" class="error-info">
                <text class="error-icon">⚠</text>
                <text class="error-text">{{item.errorMsg || '发送失败'}}</text>
                <text class="retry-btn" bindtap="handleRetry" data-id="{{item.id}}">重试</text>
              </view>

              <!-- 操作按钮行：复制 · 点赞 · 点踩 · 重新生成 -->
              <view wx:if="{{item.status === 'sent'}}" class="action-buttons">
                <text wx:if="{{showCopyBtn}}" class="action-btn" bindtap="handleCopyContent" data-content="{{item.content}}">📋</text>
                <text class="action-btn {{item.feedback === 'like' ? 'action-btn-active' : ''}}" bindtap="handleFeedback" data-id="{{item.id}}" data-type="like">👍</text>
                <text class="action-btn {{item.feedback === 'dislike' ? 'action-btn-active' : ''}}" bindtap="handleFeedback" data-id="{{item.id}}" data-type="dislike">👎</text>
                <text class="action-btn" bindtap="handleRegenerate" data-id="{{item.id}}">🔄</text>
              </view>
            </view>
          </view>
        </block>

        <view id="scroll-bottom" style="height: 24rpx;"></view>
      </view>
    </scroll-view>

    <!-- 回到底部 -->
    <view wx:if="{{showScrollToBottom}}" class="scroll-to-bottom" bindtap="scrollToBottom">
      <text class="to-bottom-icon">↓</text>
    </view>

    <!-- 底部输入区域（悬浮胶囊） -->
    <view class="footer-area">
      <view wx:if="{{uploadedFiles.length > 0}}" class="file-preview-row">
        <view wx:for="{{uploadedFiles}}" wx:key="id" class="file-preview-item">
          <image class="file-preview-img" src="{{item.path}}" mode="aspectFill"
            bindtap="handlePreviewFile" data-path="{{item.path}}" />
          <view class="file-remove-btn" catchtap="handleRemoveFile" data-id="{{item.id}}">
            <text class="file-remove-x">✕</text>
          </view>
        </view>
      </view>

      <view class="input-row">
        <image wx:if="{{enableFileUpload && !isGenerating}}" class="input-btn upload-btn"
          src="/res/search/add_files.png" mode="aspectFit" bindtap="handleChooseImage" />

        <view class="textarea-wrapper">
          <textarea class="message-textarea" value="{{inputValue}}"
            placeholder="输入消息，或上传图片..." placeholder-style="color: #bbb;font-size: 32rpx;"
            maxlength="2000" auto-height="{{true}}"
            show-confirm-bar="{{false}}" confirm-type="send"
            cursor-spacing="12" adjust-position="{{true}}"
            bindinput="onInputChange" bindfocus="onInputFocus" bindconfirm="handleSend"
          />
        </view>

        <view wx:if="{{inputValue && !isGenerating}}" class="send-btn" bindtap="handleSend">
          <image class="send-icon" src="/res/search/send_icon.png" mode="aspectFit"/>
        </view>
        <view wx:elif="{{isGenerating}}" class="stop-btn" bindtap="handleStop">
          <text class="stop-icon">■</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 清空确认弹窗 -->
  <view wx:if="{{showClearConfirm}}" class="modal-overlay" bindtap="handleCancelClear">
    <view class="modal-dialog" catchtap="">
      <text class="modal-title">清空对话</text>
      <text class="modal-desc">确认清空所有对话记录？此操作不可恢复。</text>
      <view class="modal-buttons">
        <text class="modal-btn cancel-btn" bindtap="handleCancelClear">取消</text>
        <text class="modal-btn confirm-btn" bindtap="handleConfirmClear">确认清空</text>
      </view>
    </view>
  </view>

</view>
