/* pages/browse/browse.wxss —— 清新薄荷绿主题 */
page {
  background: linear-gradient(180deg, #f5fffa 0%, #e8f5ee 100%);
}

.page-container {
  padding: 20rpx 20rpx 120rpx;
}

/* ===== 顶部操作栏 ===== */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 20rpx;
  margin-bottom: 16rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(126, 201, 164, 0.12);
}

.top-left {
  display: flex;
  align-items: center;
}

.top-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.top-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3a5c4a;
}

.btn-clear {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #7ec9a4 0%, #5daa82 100%);
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(126, 201, 164, 0.25);
}

.btn-clear-hover {
  transform: scale(0.95);
  opacity: 0.85;
}

.btn-clear-text {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
}

/* ===== 加载中 ===== */
.loading-box {
  text-align: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #8aac96;
}

/* ===== 三列图片网格 ===== */
.grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 0 10rpx;
}

.cell {
  width: 226rpx;
  margin-bottom: 18rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 4rpx 14rpx rgba(126, 201, 164, 0.10);
  transition: all 0.15s ease;
}

.cell:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(126, 201, 164, 0.16);
}

.cell-img {
  width: 226rpx;
  height: 300rpx;
  display: block;
  background: #e8f5ee;
}

.cell-time {
  display: block;
  padding: 12rpx 10rpx;
  font-size: 20rpx;
  color: #8aac96;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 加载更多 ===== */
.load-more {
  text-align: center;
  padding: 30rpx 0 40rpx;
}

.load-more-text {
  font-size: 24rpx;
  color: #b0c8b8;
}

/* ===== 空状态 ===== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #8aac96;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #b0c8b8;
}
