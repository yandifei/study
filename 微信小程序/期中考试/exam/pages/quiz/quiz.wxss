/* pages/quiz/quiz.wxss */
.question {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}
.option {
  display: block;
  padding: 10rpx 0;
  font-size: 30rpx;
}
.switch-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.input-field {
  border: 1px solid #ddd;
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}
.picker-display {
  padding: 16rpx;
  border: 1px solid #ddd;
  border-radius: 8rpx;
  color: #333;
}
.btn-group {
  display: flex;
  justify-content: space-around;
  margin: 40rpx 20rpx;
}
.btn-group button {
  width: 40%;
}